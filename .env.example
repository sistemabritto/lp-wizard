# ============================================
# LP WIZARD — Variáveis de Ambiente
# ============================================
# 1. cp .env.example .env
# 2. O /ping-pong preenche a maioria
# 3. NUNCA faça commit do .env

# ============================================
# OBRIGATÓRIO
# ============================================

# --- Geração de Imagens (GRÁTIS) ---
# aistudio.google.com → Get API Key
GOOGLE_API_KEY=

# --- Link de Conversão ---
# Checkout, WhatsApp (5511999999999) ou formulário
CHECKOUT_URL=

# ============================================
# Preenchido pelo /ping-pong
# ============================================

PUBLIC_SITE_TITLE=
PUBLIC_SITE_DESCRIPTION=
PUBLIC_CTA_TEXT=Quero acesso agora
PUBLIC_PRICE=
PUBLIC_ORIGINAL_PRICE=
PUBLIC_AUTHOR_NAME=
PUBLIC_AUTHOR_EMAIL=
PUBLIC_INSTAGRAM_URL=
PUBLIC_YOUTUBE_URL=

# ============================================
# Tracking (opcional)
# ============================================

PUBLIC_META_PIXEL_ID=
PUBLIC_GTM_ID=
PUBLIC_GA4_ID=

# ============================================
# Deploy Automático (opcional)
# ============================================

# github.com/settings/tokens/new → scope: repo
GITHUB_TOKEN=
# vercel.com/account/tokens → Full Account
VERCEL_TOKEN=

# ============================================
# Site
# ============================================

PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_FAVICON=/favicon.svg
