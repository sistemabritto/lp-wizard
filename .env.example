# ============================================
# PROTOCOLO S1 — v5
# ============================================
# 1. cp .env.example .env
# 2. O protocolo preenche automaticamente
# 3. NUNCA faça commit do .env

# --- Preenchido pelo /ping-pong ---
PUBLIC_SITE_TITLE=
PUBLIC_SITE_DESCRIPTION=
PUBLIC_CTA_TEXT=Quero acesso agora
PUBLIC_PRICE=
PUBLIC_ORIGINAL_PRICE=
PUBLIC_AUTHOR_NAME=
PUBLIC_AUTHOR_EMAIL=
PUBLIC_INSTAGRAM_URL=
PUBLIC_YOUTUBE_URL=
PUBLIC_CONSULTANT_URL=

# --- Checkout (obrigatório) ---
# Link de pagamento, WhatsApp (5511999999999) ou formulário
PUBLIC_CHECKOUT_URL=

# --- Tracking (opcional) ---
PUBLIC_META_PIXEL_ID=
PUBLIC_GTM_ID=
PUBLIC_GA4_ID=

# --- Site ---
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_FAVICON=/favicon.svg

# --- Deploy automático (opcional) ---
# github.com/settings/tokens/new → scope: repo
GITHUB_TOKEN=
# vercel.com/account/tokens → Full Account
VERCEL_TOKEN=

# --- Geração de Imagens via OpenRouter ---
# openrouter.ai/keys
OPENROUTER_API_KEY=

# Modelo de geração — descomente o que quiser usar:
# ~R$0,08/img — econômico
# IMAGE_MODEL=black-forest-labs/flux-2-klein
# ~R$0,23/img — recomendado ← padrão
IMAGE_MODEL=bytedance-seed/seedream-4.5
# ~R$0,39/img — premium (melhor para texto em imagem)
# IMAGE_MODEL=google/gemini-flash-image-preview
# ~R$0,78/img — qualidade máxima
# IMAGE_MODEL=google/gemini-pro-image-preview

# Modelo de visão — analisa imagens geradas (gratuito)
VISION_MODEL=google/gemini-3-flash-preview
